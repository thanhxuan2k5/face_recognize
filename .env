# Camera Settings
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Detection Thresholds
DETECTION_THRESHOLD=0.5
RECOGNITION_THRESHOLD=0.45
ANTI_SPOOF_THRESHOLD=0.0

# Frame Processing
FRAME_SKIP=3
FRAME_QUEUE_MAXSIZE=1

# Model Paths (relative to project root)
YOLO_WEIGHT=weights/yolov8n-face.pt
ARCFACE_WEIGHT=weights/arcface_r100.pth
SILENT_FACE_WEIGHT=weights/silent_face.pth

# Database & Index
DB_PATH=data/persons.db
FAISS_INDEX_PATH=data/faiss.index
FACES_DIR=data/faces

# UI
UI_TARGET_FPS=30
UI_THEME=dark
